# Web app configuration (Next.js). Copy to .env.local and fill in.
# All values are read at build time via process.env (see apps/web/lib/).

# Base URL of the Litmuz REST API (apps/api). Empty means same-origin.
NEXT_PUBLIC_API_BASE=https://YOUR_API_URL

# Optional auth (email one-time-code sign-in). Leave BOTH blank to run the app "open"
# (dark-ship): no sign-in, every request keyed to a default principal. Set both to enable
# authenticated, per-user sessions. The AWS region is derived from the user pool id.
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
